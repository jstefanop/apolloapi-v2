#!/bin/bash
set -Eeuo pipefail

YELLOW='\033[1;33m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

# FACTORY IMAGE BUILD TOOL — DESTRUCTIVE BY DESIGN.
# This script updates a live Solo Node image-building system before it is shut
# down and captured for production SD cards. It intentionally removes all
# device-local database and runtime credential state, and leaves services
# stopped. Never run this script on a deployed customer device.

if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}Image update must be run by root or with sudo${NC}"
    exit 1
fi

APOLLO_DIR='/opt/apolloapi'
UI_DIR="${APOLLO_DIR}/apolloui-v2"
STATE_DIR='/var/lib/apollo'

echo -e "${YELLOW} ---> Stopping image services${NC}"
for unit in \
    apollo-api.service \
    apollo-ui-v2.service \
    ckpool.service \
    apollo-miner.service \
    node.service \
    apollo-bootstrap.service; do
    systemctl stop "$unit" >/dev/null 2>&1 || true
    if systemctl is-active --quiet "$unit"; then
        echo -e "${RED}Could not stop ${unit}; refusing to sanitize the image${NC}" >&2
        exit 1
    fi
done

#### SYSTEM PACKAGES ####
#########################
echo -e "${YELLOW} ---> Installing and upgrading required system packages${NC}"
apt-get update
apt-get -y upgrade

git config --global --add safe.directory "$APOLLO_DIR"
git config --global --add safe.directory "$UI_DIR"
chown -R futurebit:futurebit "$APOLLO_DIR"

set +u
. /usr/local/nvm/nvm.sh
nvm use 21
set -u

### API ###
#############
echo -e "${YELLOW} ---> Updating API modules${NC}"
git -C "$APOLLO_DIR" reset --hard
git -C "$APOLLO_DIR" pull --ff-only
cd "$APOLLO_DIR"
yarn

### UI ###
############
echo -e "${YELLOW} ---> Updating UI modules${NC}"
git -C "$UI_DIR" reset --hard
git -C "$UI_DIR" pull --ff-only
cd "$UI_DIR"
yarn --ignore-engines

echo -e "${YELLOW} ---> Building UI (could take a few minutes)${NC}"
rm -rf .next
yarn build
yarn cache clean

chown -R futurebit:futurebit "$APOLLO_DIR"

### BINARIES ###
################
echo -e "${YELLOW} ---> Updating system binaries${NC}"
arch=$(uname -m)
install -m 755 \
    "${APOLLO_DIR}/backend/apollo-miner/bin/${arch}/apollo-miner" \
    "${APOLLO_DIR}/backend/apollo-miner/futurebit-miner"
install -m 755 \
    "${APOLLO_DIR}/backend/apollo-miner/bin/${arch}/apollo-miner-v2" \
    "${APOLLO_DIR}/backend/apollo-miner/futurebit-miner-v2"
install -m 755 \
    "${APOLLO_DIR}/backend/apollo-miner/bin/${arch}/apollo-helper" \
    "${APOLLO_DIR}/backend/apollo-miner/apollo-helper"
install -m 755 \
    "${APOLLO_DIR}/backend/ckpool/bin/${arch}/ckpool" \
    "${APOLLO_DIR}/backend/ckpool/ckpool"

### SYSTEMD ###
###############
echo -e "${YELLOW} ---> Updating systemd files${NC}"
for unit in \
    apollo-bootstrap.service \
    apollo-api.service \
    apollo-ui-v2.service \
    apollo-miner.service \
    node.service \
    ckpool.service \
    rc-local.service; do
    install -m 644 \
        "${APOLLO_DIR}/backend/systemd/${unit}" \
        "/etc/systemd/system/${unit}"
done
install -m 755 "${APOLLO_DIR}/backend/rc.local" /etc/rc.local

### FACTORY STATE RESET ###
###########################
echo -e "${YELLOW} ---> Removing device-local state for image capture${NC}"
rm -f "${APOLLO_DIR}/futurebit.sqlite"
rm -rf "$STATE_DIR"
rm -f \
    "${APOLLO_DIR}/backend/node/api.conf" \
    "${APOLLO_DIR}/backend/node/user.conf" \
    "${APOLLO_DIR}/backend/node/bitcoin.conf" \
    "${APOLLO_DIR}/backend/node/bitcoind" \
    "${APOLLO_DIR}/backend/ckpool/ckpool.conf"
install -d -o futurebit -g futurebit -m 700 "$STATE_DIR"

systemctl daemon-reload
systemctl enable \
    apollo-bootstrap.service \
    apollo-api.service \
    apollo-ui-v2.service \
    apollo-miner.service \
    node.service \
    rc-local.service
systemctl disable ckpool.service >/dev/null 2>&1 || true

echo -e "${GREEN} ---> Solo Node factory image update complete; services remain stopped${NC}"
