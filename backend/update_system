#!/bin/bash
set -Eeuo pipefail

YELLOW='\033[1;33m'
NC='\033[0m'
TMPFILE='/tmp/update_progress'
SOLO_REQUEST_FILE='/run/apollo-update-solo-requested-status'
APOLLO_DIR='/opt/apolloapi'
UI_DIR="${APOLLO_DIR}/apolloui-v2"
STATE_DIR='/var/lib/apollo'
DATABASE_URL="${APOLLO_DIR}/futurebit.sqlite"

preserve_solo_intent() {
    if [ ! -e "$SOLO_REQUEST_FILE" ] && [ -f "$DATABASE_URL" ]; then
        local requested_status
        requested_status=$(sqlite3 "$DATABASE_URL" \
            "SELECT COALESCE(requested_status, '')
               FROM service_status
              WHERE service_name = 'solo'
              ORDER BY id DESC
              LIMIT 1;" 2>/dev/null || true)
        (umask 077; printf '%s\n' "$requested_status" > "$SOLO_REQUEST_FILE")
    fi
}

restore_solo_intent() {
    [ -f "$SOLO_REQUEST_FILE" ] || return 0

    if [ -f "$DATABASE_URL" ]; then
        local requested_status
        requested_status=$(<"$SOLO_REQUEST_FILE")
        case "$requested_status" in
            online|offline)
                sqlite3 "$DATABASE_URL" \
                    "UPDATE service_status
                        SET status = 'pending',
                            requested_status = '${requested_status}',
                            requested_at = CURRENT_TIMESTAMP
                      WHERE service_name = 'solo';"
                ;;
            '')
                sqlite3 "$DATABASE_URL" \
                    "UPDATE service_status
                        SET requested_status = NULL,
                            requested_at = NULL
                      WHERE service_name = 'solo';"
                ;;
        esac
    fi

    rm -f "$SOLO_REQUEST_FILE"
}

on_error() {
    local status=$?
    trap - ERR
    restore_solo_intent || true
    rm -f "$TMPFILE"
    echo "Update failed; the system was not rebooted" >&2
    exit "$status"
}
trap on_error ERR

stop_runtime_services() {
    echo -e "${YELLOW} ---> Stopping Bitcoin and CKPool services${NC}"
    systemctl stop ckpool.service
    systemctl stop node.service

    if systemctl is-active --quiet ckpool.service ||
       pgrep -u futurebit -x ckpool >/dev/null 2>&1; then
        echo "CKPool did not stop cleanly" >&2
        return 1
    fi
    if systemctl is-active --quiet node.service ||
       pgrep -u futurebit -x bitcoind >/dev/null 2>&1; then
        echo "Bitcoin node did not stop cleanly" >&2
        return 1
    fi
}

preserve_solo_intent

# The updater that launched this script may be from the pre-refactor release.
# Install the new graceful-stop definitions before touching active binaries,
# then stop again even if a newer outer updater already did so.
for unit in \
    apollo-bootstrap.service \
    node.service \
    ckpool.service; do
    install -m 644 \
        "${APOLLO_DIR}/backend/systemd/${unit}" \
        "/etc/systemd/system/${unit}"
done
systemctl daemon-reload
stop_runtime_services

set +u
. /usr/local/nvm/nvm.sh
nvm use 21
set -u

echo "30" > "$TMPFILE"
echo -e "${YELLOW} ---> Updating API modules${NC}"
cd "$APOLLO_DIR"
yarn

echo "40" > "$TMPFILE"
echo -e "${YELLOW} ---> Updating UI modules${NC}"
cd "$UI_DIR"
yarn --ignore-engines

echo "50" > "$TMPFILE"
echo -e "${YELLOW} ---> Building UI (could take a few minutes)${NC}"
rm -rf .next
yarn build
yarn cache clean

echo "70" > "$TMPFILE"
echo -e "${YELLOW} ---> Updating system binaries${NC}"
arch=$(uname -m)
install -m 755 \
    "${APOLLO_DIR}/backend/apollo-miner/bin/${arch}/apollo-miner" \
    "${APOLLO_DIR}/backend/apollo-miner/futurebit-miner"
install -m 755 \
    "${APOLLO_DIR}/backend/apollo-miner/bin/${arch}/apollo-miner-v2" \
    "${APOLLO_DIR}/backend/apollo-miner/futurebit-miner-v2"
install -m 755 \
    "${APOLLO_DIR}/backend/apollo-miner/bin/${arch}/apollo-helper" \
    "${APOLLO_DIR}/backend/apollo-miner/apollo-helper"
install -m 755 \
    "${APOLLO_DIR}/backend/ckpool/bin/${arch}/ckpool" \
    "${APOLLO_DIR}/backend/ckpool/ckpool"

echo "85" > "$TMPFILE"
echo -e "${YELLOW} ---> Validating database and runtime configuration${NC}"
cd "$APOLLO_DIR"
install -d -o futurebit -g futurebit -m 700 "$STATE_DIR"
sudo -u futurebit env \
    NODE_ENV=production \
    APOLLO_STATE_DIR="$STATE_DIR" \
    /usr/local/nvm/versions/node/v21.6.2/bin/node \
    "${APOLLO_DIR}/src/bootstrap.js"

# A live device capable of running the updater has already completed the
# legacy one-time root resize. Factory image updaters delete this marker so
# newly imaged devices still perform their first-boot resize attempt.
install -o futurebit -g futurebit -m 600 \
    /dev/null "${STATE_DIR}/root-resize-attempted"

# Remove legacy runtime copies only after bootstrap has migrated their database
# state and written the durable files under /var/lib/apollo.
rm -f \
    "${APOLLO_DIR}/backend/node/api.conf" \
    "${APOLLO_DIR}/backend/node/user.conf" \
    "${APOLLO_DIR}/backend/node/bitcoin.conf" \
    "${APOLLO_DIR}/backend/node/bitcoind" \
    "${APOLLO_DIR}/backend/ckpool/ckpool.conf"

echo "90" > "$TMPFILE"
echo -e "${YELLOW} ---> Updating systemd files${NC}"
for unit in \
    apollo-bootstrap.service \
    apollo-api.service \
    apollo-ui-v2.service \
    apollo-miner.service \
    node.service \
    ckpool.service \
    rc-local.service \
    swap.service; do
    install -m 644 \
        "${APOLLO_DIR}/backend/systemd/${unit}" \
        "/etc/systemd/system/${unit}"
done
install -m 755 "${APOLLO_DIR}/backend/rc.local" /etc/rc.local

systemctl daemon-reload
systemctl enable \
    apollo-bootstrap.service \
    apollo-api.service \
    apollo-ui-v2.service \
    apollo-miner.service \
    node.service \
    rc-local.service \
    swap.service
systemctl disable ckpool.service >/dev/null 2>&1 || true

restore_solo_intent

echo "100" > "$TMPFILE"
rm -f "$TMPFILE"
echo -e "${YELLOW} ---> Rebooting${NC}"
systemctl reboot
